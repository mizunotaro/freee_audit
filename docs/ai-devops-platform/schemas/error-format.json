{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "error-format.json",
  "title": "Error Format",
  "description": "Unified error format for AI DevOps Platform",
  "type": "object",
  "required": ["success"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether the operation succeeded"
    },
    "data": {
      "type": "object",
      "description": "Result data if successful",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "description": "Error details if failed",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "RATE_LIMIT",
            "TIMEOUT",
            "PERMISSION",
            "VALIDATION",
            "UNKNOWN",
            "NETWORK",
            "AUTH"
          ],
          "description": "Error code"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message",
          "minLength": 1,
          "maxLength": 1000
        },
        "retryable": {
          "type": "boolean",
          "description": "Whether the error is retryable",
          "default": false
        },
        "context": {
          "type": "object",
          "description": "Additional error context",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
