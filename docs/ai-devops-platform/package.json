{
  "name": "ai-devops-platform",
  "version": "1.0.0",
  "description": "AI-powered automated development system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --passWithNoTests --coverage",
    "clean": "rm -rf dist node_modules",
    "validate": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "keywords": [
    "ai",
    "automation",
    "devops",
    "github-actions",
    "opencode",
    "glm5"
  ],
  "author": "mizunotaro",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
