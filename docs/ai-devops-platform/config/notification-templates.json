{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "templates": {
    "github_comment": {
      "critical": {
        "header": ":rotating_light: **CRITICAL Security Alert Detected**",
        "body": "An immediate security threat has been identified that requires urgent attention.\n\n**Action Required:** Immediate manual review and remediation.",
        "footer": "_This is an automated security notification from AI-DevOps Platform_"
      },
      "high": {
        "header": ":warning: **HIGH Security Alert Detected**",
        "body": "A significant security threat has been identified that requires prompt attention.\n\n**Action Required:** Manual review within 1 hour.",
        "footer": "_This is an automated security notification from AI-DevOps Platform_"
      },
      "medium": {
        "header": ":information_source: **Security Warning Detected**",
        "body": "A potential security concern has been identified.\n\n**Action Required:** Review within 24 hours.",
        "footer": "_This is an automated security notification from AI-DevOps Platform_"
      },
      "low": {
        "header": ":memo: **Security Notice**",
        "body": "A minor security-related event has been logged.\n\n**Action Required:** Review at your convenience.",
        "footer": "_This is an automated security notification from AI-DevOps Platform_"
      }
    },
    "email": {
      "subjects": {
        "critical": "[AI-DevOps Security] CRITICAL Alert - Immediate Action Required",
        "high": "[AI-DevOps Security] HIGH Alert - Action Required",
        "medium": "[AI-DevOps Security] Warning - Review Required",
        "low": "[AI-DevOps Security] Notice - Information"
      },
      "body_template": {
        "header": "Security Alert Notification",
        "sections": [
          {
            "title": "Alert Summary",
            "fields": ["severity", "repository", "timestamp", "session_id"]
          },
          {
            "title": "Threat Details",
            "fields": ["pattern", "source", "match", "confidence"]
          },
          {
            "title": "Actions Taken",
            "fields": ["session_terminated", "branch_isolated"]
          }
        ],
        "footer": "This is an automated notification from AI-DevOps Platform.\nDo not reply to this email.\n\nTo manage notification preferences, visit your account settings."
      }
    },
    "slack": {
      "severity_config": {
        "critical": {
          "color": "danger",
          "emoji": ":rotating_light:",
          "mention": "<!channel>",
          "urgency_text": "Immediate action required"
        },
        "high": {
          "color": "warning",
          "emoji": ":warning:",
          "mention": "<!here>",
          "urgency_text": "Action required within 1 hour"
        },
        "medium": {
          "color": "good",
          "emoji": ":information_source:",
          "mention": "",
          "urgency_text": "Review within 24 hours"
        },
        "low": {
          "color": "#808080",
          "emoji": ":memo:",
          "mention": "",
          "urgency_text": "Review at convenience"
        }
      },
      "blocks": {
        "header": {
          "type": "header",
          "text": {
            "type": "plain_text",
            "emoji": true
          }
        },
        "section": {
          "type": "section",
          "fields": []
        },
        "context": {
          "type": "context",
          "elements": []
        },
        "divider": {
          "type": "divider"
        }
      }
    },
    "webhook": {
      "format": "json",
      "payload_template": {
        "event_type": "security_alert",
        "version": "1.0",
        "timestamp": "",
        "data": {
          "severity": "",
          "repository": "",
          "threat_details": {},
          "actions_taken": [],
          "metadata": {}
        }
      }
    }
  },
  "channels": {
    "github": {
      "enabled": true,
      "priority": 1,
      "required_secrets": ["GITHUB_TOKEN"]
    },
    "email": {
      "enabled": false,
      "priority": 2,
      "required_secrets": [
        "SECURITY_EMAIL_ENABLED",
        "SECURITY_EMAIL_RECIPIENTS",
        "SECURITY_EMAIL_SMTP_SERVER",
        "SECURITY_EMAIL_SMTP_PORT",
        "SECURITY_EMAIL_USERNAME",
        "SECURITY_EMAIL_PASSWORD"
      ],
      "fallback_command": "mail"
    },
    "slack": {
      "enabled": true,
      "priority": 3,
      "required_secrets": ["SLACK_SECURITY_WEBHOOK"],
      "rate_limit": {
        "critical": 0,
        "high": 60,
        "medium": 300,
        "low": 3600
      }
    }
  },
  "routing_rules": [
    {
      "severity": ["critical"],
      "channels": ["github", "email", "slack"],
      "escalation": {
        "delay_minutes": 15,
        "escalate_to": ["security-team@company.com"]
      }
    },
    {
      "severity": ["high"],
      "channels": ["github", "slack"],
      "escalation": {
        "delay_minutes": 60,
        "escalate_to": ["security-team@company.com"]
      }
    },
    {
      "severity": ["medium"],
      "channels": ["github", "slack"],
      "escalation": null
    },
    {
      "severity": ["low"],
      "channels": ["github"],
      "escalation": null
    }
  ],
  "rate_limiting": {
    "enabled": true,
    "window_seconds": 60,
    "max_notifications": {
      "critical": 10,
      "high": 5,
      "medium": 3,
      "low": 1
    },
    "aggregation": {
      "enabled": true,
      "window_seconds": 300,
      "min_events": 3
    }
  },
  "deduplication": {
    "enabled": true,
    "hash_fields": ["pattern", "source", "repository"],
    "ttl_seconds": 3600
  }
}
