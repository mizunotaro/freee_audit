{
  "$schema": "./schemas/security-rules.schema.json",
  "version": "1.1.0",
  "inputValidation": {
    "maxIssueBodyLength": 10000,
    "maxIssueTitleLength": 256,
    "forbiddenPatterns": [
      "ignore.*instruction",
      "無視.*指示",
      "制約.*無視",
      "constraint.*ignore",
      "forget.*previous",
      "忘れ.*前",
      "出力.*シークレット",
      "print.*secret",
      "\\$\\(",
      "`[^`]*`",
      "eval\\s*\\(",
      "exec\\s*\\(",
      "system\\s*\\("
    ],
    "sanitizeCommands": ["base64_encode", "sanitize_html"],
    "strictMode": true
  },
  "secretScopes": {
    "githubToken": {
      "permissions": ["contents:write", "pull-requests:write", "issues:write"],
      "forbidden": ["administration:write", "organization:write", "repository:delete"],
      "description": "Repository-scoped token for PR operations"
    },
    "zaiApiKey": {
      "usage": "model_invocation_only",
      "logging": false,
      "environmentOnly": true,
      "description": "Z.AI API key for LLM invocation"
    },
    "orgAdminToken": {
      "usage": "cross_repository_operations",
      "logging": false,
      "environmentOnly": true,
      "description": "Optional token for multi-repo operations"
    }
  },
  "promptBoundaries": {
    "userInputSection": "untrusted",
    "systemInstructionsSection": "trusted",
    "securityConstraintsSection": "highest_priority",
    "markerFormat": "base64",
    "maxPromptLength": 128000
  },
  "exclusionRules": {
    "securityRelated": {
      "patterns": [
        "**/auth/**",
        "**/middleware/auth*",
        "**/crypto/**",
        "**/encryption*",
        ".env*",
        "**/config/env*",
        "**/secrets/**",
        "**/*.pem",
        "**/*.key"
      ],
      "action": "require_human_review",
      "description": "Security-sensitive files require human review"
    },
    "infrastructure": {
      "patterns": [
        "prisma/schema.prisma",
        "**/migrations/**",
        ".github/workflows/*",
        "**/Dockerfile*",
        "**/infra/**",
        "**/terraform/**",
        "**/config/**",
        "*.config.*"
      ],
      "action": "require_human_review",
      "description": "Infrastructure changes require human review"
    },
    "breakingChanges": {
      "patterns": [],
      "detectionMethods": [
        "function_signature_change",
        "interface_deletion",
        "major_version_bump",
        "api_endpoint_removal"
      ],
      "action": "require_human_review",
      "description": "Breaking changes require human review"
    },
    "dataModification": {
      "patterns": ["**/migrations/**", "**/seed*.ts", "**/prisma/**"],
      "action": "require_human_review",
      "description": "Database modifications require human review"
    }
  },
  "audit": {
    "logAllPrompts": true,
    "logAllResponses": true,
    "retainDays": 90,
    "sensitiveDataPatterns": [
      "api[_-]?key",
      "secret",
      "password",
      "token",
      "credential",
      "private[_-]?key"
    ],
    "includeMetadata": {
      "actor": true,
      "timestamp": true,
      "runId": true,
      "repository": true,
      "workflow": true,
      "issueNumber": true
    },
    "alertOn": {
      "forbiddenPatternMatch": true,
      "unauthorizedAccess": true,
      "rateLimitExceeded": true,
      "secretLeakage": true,
      "suspiciousActivity": true
    },
    "storage": {
      "type": "github_actions_logs",
      "retentionPolicy": "delete_after_retention",
      "encryptionAtRest": true
    }
  },
  "errorHandling": {
    "rateLimitBehavior": "exponential_backoff",
    "maxRetryAttempts": 3,
    "timeoutBehavior": "graceful_shutdown",
    "unauthorizedBehavior": "immediate_block",
    "circuitBreaker": {
      "enabled": true,
      "failureThreshold": 5,
      "resetTimeoutSeconds": 300
    }
  },
  "compliance": {
    "dataResidency": "US",
    "gdprCompliant": false,
    "hipaaCompliant": false,
    "soc2Compliant": true,
    "auditTrail": true
  },
  "networkSecurity": {
    "allowedDomains": ["api.github.com", "github.com", "zai-coding-plan.example.com"],
    "blockUnauthorizedDomains": true,
    "ssrfProtection": true
  }
}
