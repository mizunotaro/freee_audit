{
  "$schema": "./schemas/threat-patterns.schema.json",
  "version": "1.0.0",
  "patterns": {
    "critical": [
      {
        "id": "CRIT-001",
        "name": "DynamicCodeExecution",
        "description": "eval(), exec(), Function()コンストラクタによる動的コード実行の検知",
        "patterns": [
          "eval\\s*\\(",
          "exec\\s*\\(",
          "execfile\\s*\\(",
          "compile\\s*\\(",
          "new\\s+Function\\s*\\(",
          "Function\\s*\\(",
          "setTimeout\\s*\\(\\s*[\"']",
          "setInterval\\s*\\(\\s*[\"']"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["javascript", "typescript", "python", "ruby"]
      },
      {
        "id": "CRIT-002",
        "name": "ChildProcessExecution",
        "description": "child_process, subprocess, os.system等の外部プロセス実行の検知",
        "patterns": [
          "require\\s*\\(\\s*['\"]child_process['\"]\\s*\\)",
          "import.*child_process",
          "spawn\\s*\\(",
          "exec\\s*\\(",
          "execSync\\s*\\(",
          "execFile\\s*\\(",
          "subprocess\\.",
          "os\\.system\\s*\\(",
          "os\\.popen\\s*\\(",
          "Popen\\s*\\(",
          "system\\s*\\(",
          "backticks?\\s*`",
          "\\%x\\{"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["javascript", "typescript", "python", "ruby"]
      },
      {
        "id": "CRIT-003",
        "name": "HardcodedSecrets",
        "description": "パスワード、APIキー、シークレット等の機密情報ハードコード検知",
        "patterns": [
          "password\\s*[=:]\\s*['\"][^'\"]+['\"]",
          "passwd\\s*[=:]\\s*['\"][^'\"]+['\"]",
          "api[_-]?key\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
          "secret[_-]?key\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
          "access[_-]?key\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
          "private[_-]?key\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
          "auth[_-]?token\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
          "bearer\\s+[a-zA-Z0-9_-]{20,}",
          "sk-[a-zA-Z0-9]{20,}",
          "sk-ant-[a-zA-Z0-9]{20,}",
          "sk-or-[a-zA-Z0-9]{20,}",
          "AIza[a-zA-Z0-9_-]{35,}",
          "ghp_[a-zA-Z0-9]{36,}",
          "gho_[a-zA-Z0-9]{36,}",
          "github_pat_[a-zA-Z0-9_]{22,}"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["*"]
      },
      {
        "id": "CRIT-004",
        "name": "DataExfiltration",
        "description": "外部サーバーへのデータ送信コードの検知",
        "patterns": [
          "fetch\\s*\\(\\s*['\"]https?://(?!api\\.github\\.com|github\\.com)[^'\"]+",
          "axios\\.(get|post|put|delete|patch)\\s*\\(\\s*['\"]https?://(?!api\\.github\\.com|github\\.com)",
          "request\\.(get|post|put|delete)\\s*\\(\\s*['\"]https?://(?!api\\.github\\.com|github\\.com)",
          "http\\.(get|post|request)\\s*\\(",
          "https\\.(get|post|request)\\s*\\(",
          "urllib\\.request\\.urlopen",
          "requests\\.(get|post|put|delete)\\s*\\(",
          "net\\.http\\.(Get|Post)",
          "curl_exec\\s*\\(",
          "file_get_contents\\s*\\(\\s*['\"]https?://",
          "\\.send\\s*\\(.*\\bdata\\b",
          "\\.send\\s*\\(.*\\bbody\\b",
          "FormData\\s*\\(\\s*\\)"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["javascript", "typescript", "python", "go", "php"]
      },
      {
        "id": "CRIT-005",
        "name": "DestructiveFileOperations",
        "description": "ファイルシステム全削除・破壊的操作の検知",
        "patterns": [
          "rm\\s+-rf\\s+/",
          "rm\\s+-rf\\s+~",
          "rm\\s+-rf\\s+\\*",
          "del\\s+/[sS]\\s+\\\\",
          "rmdir\\s+/[sS]",
          "format\\s+[cC]:",
          "shutil\\.rmtree\\s*\\(",
          "os\\.rmdir\\s*\\(",
          "fs\\.rmdir\\s*\\(",
          "fs\\.rm\\s*\\(.*recursive\\s*:\\s*true",
          "rimraf\\s*\\(",
          "del\\s*\\(\\s*\\[",
          "emptyDir\\s*\\(",
          "truncate\\s*\\(",
          "/dev/null",
          ">\\s*/dev/sd",
          "dd\\s+if=.*of=/dev/"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["*"]
      },
      {
        "id": "CRIT-006",
        "name": "PrivilegeEscalation",
        "description": "権限昇格・sudo・管理者権限取得の検知",
        "patterns": [
          "sudo\\s+",
          "su\\s+",
          "chmod\\s+[0-7]*777",
          "chmod\\s+u\\+s",
          "chmod\\s+g\\+s",
          "chown\\s+root",
          "setuid\\s*\\(",
          "setgid\\s*\\(",
          "process\\.setuid\\s*\\(",
          "process\\.setgid\\s*\\(",
          "require\\s*\\(\\s*['\"]sudo['\"]\\s*\\)",
          "elevatePrivileges",
          "runAsAdmin"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["*"]
      },
      {
        "id": "CRIT-007",
        "name": "CryptoMining",
        "description": "暗号通貨マイニングコードの検知",
        "patterns": [
          "crypto\\w*\\.miner",
          "coinhive",
          "minero\\.cc",
          "hashrate",
          "stratum\\+tcp://",
          "pool\\.\\w+\\.com",
          "xmr\\.",
          "monero",
          "bitcoin.*mining",
          "eth.*mining"
        ],
        "action": "immediate_stop",
        "severity": "critical",
        "languages": ["*"]
      }
    ],
    "high": [
      {
        "id": "HIGH-001",
        "name": "WebSocketConnection",
        "description": "WebSocket接続の新規追加の検知",
        "patterns": [
          "new\\s+WebSocket\\s*\\(",
          "WebSocket\\s*\\(",
          "require\\s*\\(\\s*['\"]ws['\"]\\s*\\)",
          "import.*from\\s*['\"]ws['\"]",
          "socket\\.io",
          "socket\\.connect\\s*\\(",
          "ws://",
          "wss://"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["javascript", "typescript"]
      },
      {
        "id": "HIGH-002",
        "name": "FilePermissionChanges",
        "description": "ファイル権限変更操作の検知",
        "patterns": [
          "chmod\\s*\\(",
          "fs\\.chmod\\s*\\(",
          "fs\\.chmodSync\\s*\\(",
          "os\\.chmod\\s*\\(",
          "chmod\\s+[0-7]{3,4}",
          "fchmod\\s*\\(",
          "fchmodat\\s*\\(",
          "chown\\s*\\(",
          "fs\\.chown\\s*\\(",
          "lchown\\s*\\(",
          "fchown\\s*\\("
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["javascript", "typescript", "python", "go"]
      },
      {
        "id": "HIGH-003",
        "name": "ObfuscatedCode",
        "description": "難読化コード（base64, hex等）の検知",
        "patterns": [
          "atob\\s*\\(",
          "btoa\\s*\\(",
          "Buffer\\.from\\s*\\(.*base64",
          "base64\\.decode\\s*\\(",
          "base64\\.encode\\s*\\(",
          "binascii\\.a2b_base64",
          "binascii\\.b2a_base64",
          "fromhex\\s*\\(",
          "tohex\\s*\\(",
          "hex\\.decode\\s*\\(",
          "parseInt\\s*\\(.*16\\s*\\)",
          "String\\.fromCharCode\\s*\\(",
          "\\\\x[0-9a-fA-F]{2}",
          "\\\\u[0-9a-fA-F]{4}",
          "eval\\s*\\(.*atob",
          "Function\\s*\\(.*atob",
          "obfuscat",
          "javascript:",
          "data:text/html"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["javascript", "typescript", "python"]
      },
      {
        "id": "HIGH-004",
        "name": "NetworkConfigurationChange",
        "description": "ネットワーク設定変更の検知",
        "patterns": [
          "iptables\\s+",
          "ufw\\s+",
          "firewall-cmd",
          "netsh\\s+",
          "ifconfig\\s+",
          "ip\\s+addr",
          "ip\\s+route",
          "route\\s+add",
          "route\\s+delete",
          "net\\.(Listen|Dial)\\s*\\(\\s*['\"]tcp['\"]",
          "/etc/hosts",
          "/etc/resolv\\.conf",
          "/etc/network/",
          "hosts\\s+file",
          "DNS\\s+server"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["*"]
      },
      {
        "id": "HIGH-005",
        "name": "ProcessInjection",
        "description": "プロセスインジェクション・DLLインジェクションの検知",
        "patterns": [
          "CreateRemoteThread",
          "WriteProcessMemory",
          "VirtualAllocEx",
          "LoadLibrary",
          "GetProcAddress",
          "ptrace\\s*\\(",
          "dlopen\\s*\\(",
          "inject",
          "hook",
          "detour"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["c", "cpp", "go", "rust"]
      },
      {
        "id": "HIGH-006",
        "name": "EnvironmentModification",
        "description": "環境変数・PATH変更の検知",
        "patterns": [
          "process\\.env\\[",
          "process\\.env\\.",
          "export\\s+\\w+=",
          "setenv\\s*\\(",
          "putenv\\s*\\(",
          "os\\.environ\\[",
          "os\\.setenv",
          "PATH\\s*=",
          "LD_PRELOAD",
          "LD_LIBRARY_PATH",
          "DYLD_INSERT_LIBRARIES"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["javascript", "typescript", "python", "go", "rust"]
      },
      {
        "id": "HIGH-007",
        "name": "DatabaseDirectAccess",
        "description": "データベース直接アクセス・SQL実行の検知",
        "patterns": [
          "mysql\\.query\\s*\\(",
          "pg\\.query\\s*\\(",
          "sqlite3\\.exec\\s*\\(",
          "mongoose\\.connect",
          "sequelize\\.query",
          "knex\\.raw\\s*\\(",
          "execSQL\\s*\\(",
          "cursor\\.execute\\s*\\(",
          "DROP\\s+TABLE",
          "TRUNCATE\\s+TABLE",
          "DELETE\\s+FROM",
          "GRANT\\s+ALL",
          "REVOKE\\s+"
        ],
        "action": "stop_recommended",
        "severity": "high",
        "languages": ["javascript", "typescript", "python", "go"]
      }
    ],
    "medium": [
      {
        "id": "MED-001",
        "name": "MassFileChanges",
        "description": "大量ファイル変更（50+ファイル）の検知",
        "threshold": {
          "maxFiles": 50,
          "type": "file_count"
        },
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-002",
        "name": "MassLineAdditions",
        "description": "大量行追加（1000+行）の検知",
        "threshold": {
          "maxLines": 1000,
          "type": "line_additions"
        },
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-003",
        "name": "MassLineDeletions",
        "description": "大量行削除（500+行）の検知",
        "threshold": {
          "maxLines": 500,
          "type": "line_deletions"
        },
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-004",
        "name": "DependencyChanges",
        "description": "依存関係の大幅な変更の検知",
        "patterns": [
          "package\\.json",
          "package-lock\\.json",
          "yarn\\.lock",
          "pnpm-lock\\.yaml",
          "requirements\\.txt",
          "Pipfile",
          "Pipfile\\.lock",
          "go\\.mod",
          "go\\.sum",
          "Cargo\\.toml",
          "Cargo\\.lock",
          "pom\\.xml",
          "build\\.gradle",
          "Gemfile",
          "Gemfile\\.lock"
        ],
        "threshold": {
          "maxPackages": 10,
          "type": "dependency_count"
        },
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-005",
        "name": "ConfigFileChanges",
        "description": "設定ファイル変更の検知",
        "patterns": [
          "\\.env",
          "\\.env\\.",
          "config\\.(js|ts|json|yaml|yml)",
          "\\.config\\.(js|ts|json|yaml|yml)",
          "settings\\.(py|json|yaml|yml)",
          "tsconfig\\.json",
          "eslint",
          "prettier",
          "babel\\.config",
          "webpack\\.config",
          "vite\\.config",
          "next\\.config",
          "nuxt\\.config",
          "vue\\.config",
          "jest\\.config",
          "vitest\\.config"
        ],
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-006",
        "name": "CI_CDChanges",
        "description": "CI/CDパイプライン変更の検知",
        "patterns": [
          "\\.github/workflows/",
          "\\.gitlab-ci\\.yml",
          "\\.circleci/",
          "Jenkinsfile",
          "azure-pipelines\\.yml",
          "bitbucket-pipelines\\.yml",
          "cloudbuild\\.yaml",
          "netlify\\.toml",
          "vercel\\.json"
        ],
        "action": "warning",
        "severity": "medium"
      },
      {
        "id": "MED-007",
        "name": "BinaryFileAdditions",
        "description": "バイナリファイル追加の検知",
        "patterns": [
          "\\.exe$",
          "\\.dll$",
          "\\.so$",
          "\\.dylib$",
          "\\.bin$",
          "\\.dat$",
          "\\.db$",
          "\\.sqlite$"
        ],
        "action": "warning",
        "severity": "medium"
      }
    ],
    "low": [
      {
        "id": "LOW-001",
        "name": "LargeFileSize",
        "description": "大きなファイルサイズ（1MB+）の検知",
        "threshold": {
          "maxBytes": 1048576,
          "type": "file_size"
        },
        "action": "info",
        "severity": "low"
      },
      {
        "id": "LOW-002",
        "name": "NewFileExtensions",
        "description": "新しいファイル拡張子の使用検知",
        "action": "info",
        "severity": "low"
      },
      {
        "id": "LOW-003",
        "name": "CommentRemoval",
        "description": "大量のコメント削除の検知",
        "threshold": {
          "ratio": 0.5,
          "type": "comment_removal_ratio"
        },
        "action": "info",
        "severity": "low"
      },
      {
        "id": "LOW-004",
        "name": "TodoFixmeRemoval",
        "description": "TODO/FIXMEコメントの一括削除検知",
        "patterns": ["TODO", "FIXME", "HACK", "XXX", "BUG"],
        "threshold": {
          "count": 5,
          "type": "todo_removal_count"
        },
        "action": "info",
        "severity": "low"
      }
    ]
  },
  "thresholds": {
    "maxFileDeletions": 5,
    "maxFileAdditions": 100,
    "maxLineChanges": 1000,
    "maxDirectoryDepth": 10,
    "forbiddenFiles": [
      {
        "pattern": "\\.env$",
        "reason": "Environment variables file"
      },
      {
        "pattern": "\\.env\\.",
        "reason": "Environment variables file variant"
      },
      {
        "pattern": "credentials",
        "reason": "Credentials file"
      },
      {
        "pattern": "secrets?\\.(json|yaml|yml|xml)",
        "reason": "Secrets configuration file"
      },
      {
        "pattern": "\\.pem$",
        "reason": "Private key file"
      },
      {
        "pattern": "\\.key$",
        "reason": "Key file"
      },
      {
        "pattern": "\\.p12$",
        "reason": "Certificate file"
      },
      {
        "pattern": "\\.pfx$",
        "reason": "Certificate file"
      },
      {
        "pattern": "id_rsa",
        "reason": "SSH private key"
      },
      {
        "pattern": "id_dsa",
        "reason": "SSH private key"
      },
      {
        "pattern": "id_ecdsa",
        "reason": "SSH private key"
      },
      {
        "pattern": "id_ed25519",
        "reason": "SSH private key"
      },
      {
        "pattern": "\\.ssh/",
        "reason": "SSH directory"
      },
      {
        "pattern": "\\.gnupg/",
        "reason": "GPG directory"
      },
      {
        "pattern": "wp-config\\.php",
        "reason": "WordPress configuration"
      },
      {
        "pattern": "database\\.yml",
        "reason": "Database configuration"
      },
      {
        "pattern": "local\\.settings\\.json",
        "reason": "Local settings file"
      }
    ],
    "forbiddenDirectories": [
      {
        "pattern": "\\.git/",
        "reason": "Git internal directory"
      },
      {
        "pattern": "\\.ssh/",
        "reason": "SSH directory"
      },
      {
        "pattern": "/etc/shadow",
        "reason": "System password file"
      },
      {
        "pattern": "/etc/passwd",
        "reason": "System user file"
      },
      {
        "pattern": "/proc/",
        "reason": "Process information"
      },
      {
        "pattern": "/sys/",
        "reason": "System information"
      }
    ],
    "suspiciousPatterns": {
      "highEntropyStrings": {
        "enabled": true,
        "threshold": 4.5,
        "minLength": 20,
        "description": "Detect high entropy strings (potential secrets)"
      },
      "longLines": {
        "enabled": true,
        "threshold": 1000,
        "description": "Detect unusually long lines (potential minified/obfuscated code)"
      },
      "unicodeControlChars": {
        "enabled": true,
        "description": "Detect Unicode control characters (potential homograph attacks)"
      }
    }
  },
  "actions": {
    "immediate_stop": {
      "description": "即座にセッションを停止し、アラートを発報",
      "notify": true,
      "blockCommit": true,
      "requireReview": true
    },
    "stop_recommended": {
      "description": "停止を推奨し、確認を求める",
      "notify": true,
      "blockCommit": true,
      "requireReview": true
    },
    "warning": {
      "description": "警告を表示し、継続確認を求める",
      "notify": true,
      "blockCommit": false,
      "requireReview": false
    },
    "info": {
      "description": "情報ログとして記録",
      "notify": false,
      "blockCommit": false,
      "requireReview": false
    }
  },
  "metadata": {
    "createdAt": "2026-03-09T00:00:00Z",
    "updatedAt": "2026-03-09T00:00:00Z",
    "author": "system",
    "description": "AIセッション脅威検知パターン定義 - 悪意ある動作を検知し防止するためのパターン集"
  }
}
