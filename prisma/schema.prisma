generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  name         String
  role         String     @default("VIEWER")
  companyId    String?    @map("company_id")
  company      Company?   @relation(fields: [companyId], references: [id])
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Company {
  id                     String                  @id @default(cuid())
  freeeCompanyId         String?                 @unique @map("freee_company_id")
  name                   String
  fiscalYearStart        Int                     @default(1) @map("fiscal_year_start")
  users                  User[]
  journals               Journal[]
  documents              Document[]
  budgets                Budget[]
  cashFlows              CashFlow[]
  kpis                   FinancialKPI[]
  apiKeys                ApiKey[]
  monthlyBalances        MonthlyBalance[]
  accountItems           AccountItem[]
  debts                  Debt[]
  taxSchedules           TaxSchedule[]
  boardMeetings          BoardMeeting[]
  customKPIs             CustomKPI[]
  boardReports           BoardReport[]
  analysisPrompts        AnalysisPrompt[]
  fixedAssets            FixedAsset[]
  taxEffectAccounting    TaxEffectAccounting[]
  inventoryAdjustments   InventoryAdjustment[]
  socialInsuranceSchedules SocialInsuranceSchedule[]
  socialInsurancePayments SocialInsurancePayment[]
  prepaidExpenses        PrepaidExpense[]
  accrualExpenses        AccrualExpense[]
  taxSettings            TaxSettings?
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  @@map("companies")
}

model ApiKey {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider        String
  encryptedKey    String   @map("encrypted_key")
  encryptedSecret String?  @map("encrypted_secret")
  metadata        String?
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, provider])
  @@map("api_keys")
}

model Journal {
  id             String        @id @default(cuid())
  companyId      String        @map("company_id")
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freeeJournalId String        @unique @map("freee_journal_id")
  entryDate      DateTime      @map("entry_date")
  description    String
  debitAccount   String        @map("debit_account")
  creditAccount  String        @map("credit_account")
  amount         Float
  taxAmount      Float         @default(0) @map("tax_amount")
  taxType        String?       @map("tax_type")
  documentId     String?       @unique @map("document_id")
  document       Document?     @relation(fields: [documentId], references: [id])
  auditStatus    String        @default("PENDING") @map("audit_status")
  auditResults   AuditResult[]
  syncedAt       DateTime      @map("synced_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([companyId, entryDate])
  @@index([companyId, auditStatus])
  @@map("journals")
}

model Document {
  id              String        @id @default(cuid())
  companyId       String        @map("company_id")
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freeeDocumentId String?       @unique @map("freee_document_id")
  journal         Journal?
  filePath        String        @map("file_path")
  fileType        String        @map("file_type")
  fileName        String        @map("file_name")
  fileSize        Int           @map("file_size")
  uploadDate      DateTime      @map("upload_date")
  auditResults    AuditResult[]
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([companyId])
  @@map("documents")
}

model AuditResult {
  id              String   @id @default(cuid())
  journalId       String   @map("journal_id")
  journal         Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  documentId      String?  @map("document_id")
  document        Document? @relation(fields: [documentId], references: [id])
  status          String
  issues          String
  confidenceScore Float?   @map("confidence_score")
  rawAiResponse   String?  @map("raw_ai_response")
  analyzedAt      DateTime @map("analyzed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([journalId])
  @@index([status])
  @@map("audit_results")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    String?
  result     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model Budget {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear   Int      @map("fiscal_year")
  month        Int
  departmentId String?  @map("department_id")
  accountCode  String   @map("account_code")
  accountName  String   @map("account_name")
  amount       Float
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([companyId, fiscalYear, month, departmentId, accountCode])
  @@index([companyId, fiscalYear])
  @@map("budgets")
}

model CashFlow {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear Int      @map("fiscal_year")
  month      Int
  category   String
  itemName   String   @map("item_name")
  amount     Float
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([companyId, fiscalYear, month, category, itemName])
  @@index([companyId, fiscalYear])
  @@map("cash_flows")
}

model ExchangeRate {
  id           String         @id @default(cuid())
  rateDate     DateTime       @map("rate_date")
  fromCurrency String         @map("from_currency")
  toCurrency   String         @map("to_currency")
  rate         Float
  source       String
  kpis         FinancialKPI[]
  createdAt    DateTime       @default(now()) @map("created_at")

  @@unique([rateDate, fromCurrency, toCurrency])
  @@index([rateDate])
  @@map("exchange_rates")
}

model FinancialKPI {
  id             String        @id @default(cuid())
  companyId      String        @map("company_id")
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear     Int           @map("fiscal_year")
  month          Int
  kpiName        String        @map("kpi_name")
  value          Float
  currency       String        @default("JPY")
  exchangeRateId String?       @map("exchange_rate_id")
  exchangeRate   ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  createdAt      DateTime      @default(now()) @map("created_at")

  @@unique([companyId, fiscalYear, month, kpiName, currency])
  @@index([companyId, fiscalYear])
  @@map("financial_kpis")
}

model MonthlyBalance {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear   Int      @map("fiscal_year")
  month        Int
  accountCode  String   @map("account_code")
  accountName  String   @map("account_name")
  category     String
  amount       Float
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([companyId, fiscalYear, month, accountCode])
  @@index([companyId, fiscalYear])
  @@map("monthly_balances")
}

model FreeeToken {
  id           String   @id @default(cuid())
  companyId    String   @unique @map("company_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  tokenType    String   @default("Bearer") @map("token_type")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("freee_tokens")
}

model Settings {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  theme               String   @default("system")
  aiProvider          String   @default("openai") @map("ai_provider")
  openaiApiKey        String?  @map("openai_api_key")
  geminiApiKey        String?  @map("gemini_api_key")
  claudeApiKey        String?  @map("claude_api_key")
  azureApiKey         String?  @map("azure_api_key")
  azureEndpoint       String?  @map("azure_endpoint")
  awsAccessKeyId      String?  @map("aws_access_key_id")
  awsSecretAccessKey  String?  @map("aws_secret_access_key")
  awsRegion           String?  @map("aws_region")
  gcpApiKey           String?  @map("gcp_api_key")
  gcpProjectId        String?  @map("gcp_project_id")
  secretSource        String   @default("local") @map("secret_source")
  freeeClientId       String?  @map("freee_client_id")
  freeeClientSecret   String?  @map("freee_client_secret")
  freeeCompanyId      String?  @map("freee_company_id")
  analysisPrompt      String?  @map("analysis_prompt")
  fiscalYearEndMonth  Int?     @map("fiscal_year_end_month")
  taxBusinessType     String?  @map("tax_business_type")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AccountItem {
  id                        String   @id @default(cuid())
  companyId                 String   @map("company_id")
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freeeId                   Int      @map("freee_id")
  name                      String
  shortcut                  String?
  shortcutNum               String?  @map("shortcut_num")
  categoryId                Int      @map("category_id")
  categoryName              String   @map("category_name")
  categoryType              String   @map("category_type")
  correspondingIncomeId     Int?     @map("corresponding_income_id")
  correspondingIncomeName   String?  @map("corresponding_income_name")
  correspondingExpenseId    Int?     @map("corresponding_expense_id")
  correspondingExpenseName  String?  @map("corresponding_expense_name")
  searchable                Boolean  @default(true)
  cumulable                 Boolean  @default(false)
  balance                   String
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@unique([companyId, freeeId])
  @@index([companyId, categoryType])
  @@map("account_items")
}

model Debt {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freeeDealId      String?   @map("freee_deal_id")
  partnerId        String?   @map("partner_id")
  partnerName      String?   @map("partner_name")
  description      String?
  amount           Float
  dueDate          DateTime  @map("due_date")
  paymentDate      DateTime? @map("payment_date")
  status           String    @default("PENDING")
  category         String
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([companyId, dueDate])
  @@index([companyId, status])
  @@map("debts")
}

model TaxSchedule {
  id              String       @id @default(cuid())
  companyId       String       @map("company_id")
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taxType         String       @map("tax_type")
  fiscalYear      Int          @map("fiscal_year")
  dueDate         DateTime     @map("due_date")
  amount          Float?
  status          String       @default("PENDING")
  filedDate       DateTime?    @map("filed_date")
  paidDate        DateTime?    @map("paid_date")
  note            String?
  payments        TaxPayment[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([companyId, taxType, fiscalYear])
  @@index([companyId, fiscalYear])
  @@map("tax_schedules")
}

model TaxPayment {
  id              String      @id @default(cuid())
  taxScheduleId   String      @map("tax_schedule_id")
  taxSchedule     TaxSchedule @relation(fields: [taxScheduleId], references: [id], onDelete: Cascade)
  paymentDate     DateTime    @map("payment_date")
  amount          Float
  paymentMethod   String      @map("payment_method")
  referenceNumber String?     @map("reference_number")
  note            String?
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([taxScheduleId])
  @@map("tax_payments")
}

model BoardMeeting {
  id                String       @id @default(cuid())
  companyId         String       @map("company_id")
  company           Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  meetingDate       DateTime     @map("meeting_date")
  meetingType       String       @map("meeting_type")
  agendaItems       AgendaItem[]
  minutes           String?
  status            String       @default("SCHEDULED")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@index([companyId, meetingDate])
  @@map("board_meetings")
}

model AgendaItem {
  id                  String       @id @default(cuid())
  boardMeetingId      String       @map("board_meeting_id")
  boardMeeting        BoardMeeting @relation(fields: [boardMeetingId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  category            String
  decisionType        String       @map("decision_type")
  requiredByLaw       Boolean      @default(false) @map("required_by_law")
  legalBasis          String?      @map("legal_basis")
  aiAnalysis          String?      @map("ai_analysis")
  resolution          String?
  resolutionStatus    String       @default("PENDING") @map("resolution_status")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([boardMeetingId])
  @@map("agenda_items")
}

model CustomKPI {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name               String
  code               String
  description        String?
  category           String

  calculationType    String   @map("calculation_type")
  formula            String?
  dataSource         String?  @map("data_source")

  unit               String   @default("number")
  displayFormat      String?  @map("display_format")
  decimalPlaces      Int      @default(0) @map("decimal_places")
  isVisible          Boolean  @default(true) @map("is_visible")
  sortOrder          Int      @default(0) @map("sort_order")

  targetValue        Float?   @map("target_value")
  warningThreshold   Float?   @map("warning_threshold")
  criticalThreshold  Float?   @map("critical_threshold")
  comparisonType     String   @default("higher_better") @map("comparison_type")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  values             CustomKPIValue[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("custom_kpis")
}

model CustomKPIValue {
  id             String    @id @default(cuid())
  customKPIId    String    @map("custom_kpi_id")
  customKPI      CustomKPI @relation(fields: [customKPIId], references: [id], onDelete: Cascade)

  fiscalYear     Int       @map("fiscal_year")
  month          Int

  value          Float
  previousValue  Float?    @map("previous_value")
  yoyChange      Float?    @map("yoy_change")

  isCalculated   Boolean   @default(false) @map("is_calculated")
  notes          String?

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([customKPIId, fiscalYear, month])
  @@index([customKPIId, fiscalYear])
  @@map("custom_kpi_values")
}

model BoardReport {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fiscalYear    Int      @map("fiscal_year")
  month         Int

  title         String
  summary       String?
  sections      BoardReportSection[]

  status        String   @default("DRAFT")
  generatedAt   DateTime? @map("generated_at")
  presentedAt   DateTime? @map("presented_at")

  approvedBy    String?  @map("approved_by")
  approvedAt    DateTime? @map("approved_at")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([companyId, fiscalYear, month])
  @@index([companyId, fiscalYear])
  @@map("board_reports")
}

model BoardReportSection {
  id           String      @id @default(cuid())
  reportId     String      @map("report_id")
  report       BoardReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  sectionType  String      @map("section_type")
  title        String
  content      String
  data         String?

  sortOrder    Int         @map("sort_order")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([reportId])
  @@map("board_report_sections")
}

model AnalysisPrompt {
  id                 String    @id @default(cuid())
  companyId          String?   @map("company_id")
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  analysisType       String    @map("analysis_type")
  name               String
  description        String?
  systemPrompt       String    @map("system_prompt")
  userPromptTemplate String    @map("user_prompt_template")

  variables          String

  isActive           Boolean   @default(true) @map("is_active")
  isDefault          Boolean   @default(false) @map("is_default")

  version            Int       @default(1)
  parentPromptId     String?   @map("parent_prompt_id")

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, analysisType, isActive])
  @@index([companyId, analysisType])
  @@index([analysisType, isDefault])
  @@map("analysis_prompts")
}

model FixedAsset {
  id                  String   @id @default(cuid())
  companyId           String   @map("company_id")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freeeAssetId        String?  @map("freee_asset_id")
  name                String
  acquisitionDate     DateTime @map("acquisition_date")
  acquisitionCost     Float    @map("acquisition_cost")
  salvageValue        Float    @map("salvage_value")
  usefulLife          Int      @map("useful_life")
  depreciationMethod  String   @map("depreciation_method")
  accumulatedDep      Float    @default(0) @map("accumulated_dep")
  bookValue           Float    @map("book_value")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("fixed_assets")
}

model TaxEffectAccounting {
  id                   String   @id @default(cuid())
  companyId            String   @map("company_id")
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear           Int      @map("fiscal_year")
  deferredTaxAsset     Float    @map("deferred_tax_asset")
  deferredTaxLiability Float    @map("deferred_tax_liability")
  netDeferredTax       Float    @map("net_deferred_tax")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([companyId, fiscalYear])
  @@index([companyId, fiscalYear])
  @@map("tax_effect_accounting")
}

model InventoryAdjustment {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear     Int      @map("fiscal_year")
  month          Int
  openingBalance Float    @map("opening_balance")
  closingBalance Float    @map("closing_balance")
  adjustment     Float
  journalEntryId String?  @map("journal_entry_id")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([companyId, fiscalYear, month])
  @@index([companyId, fiscalYear])
  @@map("inventory_adjustments")
}

model SocialInsuranceSchedule {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insuranceType  String   @map("insurance_type")
  taskName       String   @map("task_name")
  dueDate        DateTime @map("due_date")
  completedDate  DateTime? @map("completed_date")
  status         String   @default("PENDING")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([companyId, dueDate])
  @@index([companyId, status])
  @@map("social_insurance_schedules")
}

model SocialInsurancePayment {
  id             String    @id @default(cuid())
  companyId      String    @map("company_id")
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  insuranceType  String    @map("insurance_type")
  year           Int
  month          Int
  expectedAmount Float     @map("expected_amount")
  actualAmount   Float     @map("actual_amount")
  journalEntryId String?   @map("journal_entry_id")
  paymentDate    DateTime? @map("payment_date")
  dueDate        DateTime  @map("due_date")
  status         String    @default("PENDING")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, insuranceType, year, month])
  @@index([companyId, year, month])
  @@map("social_insurance_payments")
}

model PrepaidExpense {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountCode     String   @map("account_code")
  accountName     String   @map("account_name")
  originalAmount  Float    @map("original_amount")
  remainingAmount Float    @map("remaining_amount")
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  totalMonths     Int      @map("total_months")
  monthlyAmount   Float    @map("monthly_amount")
  status          String   @default("ACTIVE")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  amortizations   PrepaidAmortization[]

  @@index([companyId, status])
  @@map("prepaid_expenses")
}

model PrepaidAmortization {
  id             String   @id @default(cuid())
  prepaidId      String   @map("prepaid_id")
  prepaid        PrepaidExpense @relation(fields: [prepaidId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  expectedAmount Float    @map("expected_amount")
  actualAmount   Float    @map("actual_amount")
  journalEntryId String?  @map("journal_entry_id")
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([prepaidId, year, month])
  @@map("prepaid_amortizations")
}

model AccrualExpense {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountCode      String    @map("account_code")
  accountName      String    @map("account_name")
  accrualYear      Int       @map("accrual_year")
  accrualMonth     Int       @map("accrual_month")
  expectedAmount   Float     @map("expected_amount")
  actualAmount     Float     @map("actual_amount")
  accrualJournalId String?   @map("accrual_journal_id")
  paymentYear      Int?      @map("payment_year")
  paymentMonth     Int?      @map("payment_month")
  paymentJournalId String?   @map("payment_journal_id")
  status           String    @default("ACCRUED")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([companyId, accrualYear, accrualMonth])
  @@map("accrual_expenses")
}

model TaxSettings {
  id                       String   @id @default(cuid())
  companyId                String   @unique @map("company_id")
  company                  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  withholdingSpecialRule   Boolean  @default(false) @map("withholding_special_rule")
  withholdingEmployeeCount Int      @default(0) @map("withholding_employee_count")
  fiscalYearStart          Int      @default(1) @map("fiscal_year_start")
  consumptionTaxable       Boolean  @default(true) @map("consumption_taxable")
  taxFilingMethod          String   @default("BLUE") @map("tax_filing_method")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("tax_settings")
}
