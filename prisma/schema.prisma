  ocrEngine       String   @default("ndlocr") @map("ocr_engine")
  
  aiProvider      String?  @map("ai_provider")
  aiModel         String?  @map("ai_model")
  aiTemperature   Float?   @map("ai_temperature")
  aiMaxTokens     Int?     @map("ai_max_tokens")
  
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedBy       String   @map("updated_by")
  
  @@index([companyId])
  @@map("company_settings")
}

model ReceiptDocument {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  encryptedPath   String   @map("encrypted_path")
  originalName    String   @map("original_name")
  contentType     String   @map("content_type")
  fileSize        Int      @map("file_size")
  fileHash        String   @map("file_hash")
  
  ocrResult       String?  @map("ocr_result")
  ocrEngine       String?  @map("ocr_engine")
  ocrConfidence   Float?   @map("ocr_confidence")
  
  status          String   @default("uploaded")
  
  expiresAt       DateTime? @map("expires_at")
  deletedAt       DateTime? @map("deleted_at")
  
  uploadedBy      String   @map("uploaded_by")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  lastAccessedAt  DateTime? @map("last_accessed_at")
  
  journalProposal JournalProposal?
  
  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
  @@index([uploadedAt])
  @@map("receipt_documents")
}

model JournalProposal {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  documentId      String   @unique @map("document_id")
  document        ReceiptDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  userContext     String   @map("user_context")
  
  proposals       String   @map("proposals")
  
  aiProvider      String   @map("ai_provider")
  aiModel         String   @map("ai_model")
  
  status          String   @default("pending")
  
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  reviewedBy      String?  @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("journal_proposals")
}
